<footer class="footer">
  <div class="container">
    <div class="row g-4">
      <div class="col-lg-4 col-md-6">
        <div class="footer-brand">My<span>Shop</span></div>
        <p style="font-size:0.88rem; max-width:280px;">Your one-stop destination for quality products at great prices. Shop smarter, live better.</p>
      </div>
      <div class="col-lg-2 col-md-3 col-6">
        <h6>Shop</h6>
        <ul class="footer-links">
          <li><a href="/shop">All Products</a></li>
          <li><a href="/shop?category=Electronics">Electronics</a></li>
          <li><a href="/shop?category=Clothing">Clothing</a></li>
          <li><a href="/shop?category=Footwear">Footwear</a></li>
        </ul>
      </div>
      <div class="col-lg-2 col-md-3 col-6">
        <h6>Account</h6>
        <ul class="footer-links">
          <li><a href="/login">Login</a></li>
          <li><a href="/cart">My Cart</a></li>
        </ul>
      </div>
      <div class="col-lg-4 col-md-6">
        <h6>Get in Touch</h6>
        <p style="font-size:0.88rem;">📧 anuragpandey7058@gmail.com</p>
        <p style="font-size:0.88rem;">📞 +91 7058768043</p>
        <p style="font-size:0.88rem;">📍 Noida, India</p>
      </div>
    </div>

    <!-- Query Form Row -->
    <div class="row mt-4">
      <div class="col-12">
        <div class="footer-query-box">
          <h6>Send Us a Query</h6>
          <p class="footer-query-sub">Have a question or feedback? Drop us a message and we'll get back to you.</p>

          <% if (locals.querySuccess) { %>
            <div class="footer-query-success">
              <span class="footer-success-icon">✓</span>
              <span>Thanks! We'll get back to you soon.</span>
            </div>
          <% } else { %>
            <form action="/query" method="POST" class="footer-query-form">
              <div class="footer-query-row">
                <div class="footer-query-field">
                  <input type="text" name="name" class="footer-input" placeholder="Your Name" required />
                </div>
                <div class="footer-query-field">
                  <input type="email" name="email" class="footer-input" placeholder="Your Email" required />
                </div>
              </div>
              <div class="footer-query-field">
                <textarea name="message" class="footer-input footer-textarea" placeholder="Write your query here..." rows="3" required></textarea>
              </div>
              <button type="submit" class="footer-query-btn">
                Send Message <span class="footer-btn-arrow">→</span>
              </button>
            </form>
          <% } %>

        </div>
      </div>
    </div>
    <div class="footer-bottom">
      © 2026 MyShop. Built with ❤️ using Node.js &amp; Express.
    </div>
  </div>
</footer>

<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<!-- Custom JS -->
<script src="/js/main.js"></script>
</body>
</html>
