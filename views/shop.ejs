<%- include('partials/header', { title: 'Shop' }) %>

<!-- Shop Header -->
<div class="shop-header">
  <div class="container">
    <h1 style="font-family:'Syne',sans-serif; font-weight:800; font-size:2rem; margin-bottom:6px;">
      <%= selectedCategory ? selectedCategory : 'All Products' %>
    </h1>
    <p style="color:rgba(255,255,255,0.6); font-size:0.9rem; margin:0">
      <%= products.length %> product<%= products.length !== 1 ? 's' : '' %> found
    </p>
  </div>
</div>

<section class="py-5">
  <div class="container">

    <!-- Filter Pills -->
    <div class="filter-pills">
      <a href="/shop" class="filter-pill <%= !selectedCategory ? 'active' : '' %>">All</a>
      <a href="/shop?category=Electronics" class="filter-pill <%= selectedCategory === 'Electronics' ? 'active' : '' %>">💻 Electronics</a>
      <a href="/shop?category=Clothing" class="filter-pill <%= selectedCategory === 'Clothing' ? 'active' : '' %>">👕 Clothing</a>
      <a href="/shop?category=Footwear" class="filter-pill <%= selectedCategory === 'Footwear' ? 'active' : '' %>">👟 Footwear</a>
    </div>

    <!-- Products Grid -->
    <% if (products.length === 0) { %>
    <div class="empty-state">
      <span class="empty-icon">🔍</span>
      <h3 class="empty-title">No products found</h3>
      <p style="color:var(--gray); margin-bottom:20px">Try a different category</p>
      <a href="/shop" style="background:var(--primary); color:white; padding:10px 28px; border-radius:50px; text-decoration:none; font-family:'Syne',sans-serif; font-weight:700;">View All</a>
    </div>
    <% } else { %>
    <div class="row g-4">
      <% products.forEach(product => { %>
      <div class="col-lg-3 col-md-6">
        <div class="product-card">
          <div class="product-img-wrap">
            <img src="<%= product.image %>" alt="<%= product.name %>" loading="lazy">
            <span class="product-badge <%= product.badge.toLowerCase() %>"><%= product.badge %></span>
            <a href="/product/<%= product.id %>" class="quick-view-btn">View Details</a>
          </div>
          <div class="product-info">
            <div class="product-category"><%= product.category %></div>
            <a href="/product/<%= product.id %>" class="product-name"><%= product.name %></a>
            <div class="product-stars">
              ★★★★<%= product.rating >= 4.5 ? '★' : '☆' %>
              <span>(<%= product.reviews %>)</span>
            </div>
            <div class="product-price-row">
              <span class="price-current">₹<%= product.price.toLocaleString('en-IN') %></span>
              <span class="price-original">₹<%= product.originalPrice.toLocaleString('en-IN') %></span>
              <span class="price-discount">-<%= Math.round((product.originalPrice - product.price) / product.originalPrice * 100) %>%</span>
            </div>
            <button class="btn-add-cart" data-id="<%= product.id %>">Add to Cart 🛒</button>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
    <% } %>
  </div>
</section>

<%- include('partials/footer') %>
