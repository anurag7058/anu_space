<%- include('partials/header', { title: 'Shop' }) %>

<!-- Shop Header -->
<div class="shop-header">
  <div class="container">
    <h1 style="font-family:'Syne',sans-serif; font-weight:800; font-size:2rem; margin-bottom:6px;">
      <%= selectedCategory ? selectedCategory : 'All Products' %>
    </h1>
    <p style="color:rgba(255,255,255,0.6); font-size:0.9rem; margin:0">
      <%= products.length %> product<%= products.length !== 1 ? 's' : '' %> found
    </p>
  </div>
</div>

<section class="py-5">
  <div class="container">

    <!-- Category Pills -->
    <div class="filter-pills mb-2">
      <a href="/shop" class="filter-pill <%= !selectedCategory ? 'active' : '' %>">All</a>
      <a href="/shop?category=Electronics" class="filter-pill <%= selectedCategory === 'Electronics' ? 'active' : '' %>">💻 Electronics</a>
      <a href="/shop?category=Clothing"    class="filter-pill <%= selectedCategory === 'Clothing'    ? 'active' : '' %>">👕 Clothing</a>
      <a href="/shop?category=Footwear"    class="filter-pill <%= selectedCategory === 'Footwear'    ? 'active' : '' %>">👟 Footwear</a>
    </div>

    <!-- Advanced Filters Bar -->
    <form method="GET" action="/shop" id="filterForm" class="filter-bar-advanced mb-4">
      <% if (selectedCategory) { %>
        <input type="hidden" name="category" value="<%= selectedCategory %>">
      <% } %>

      <div class="filter-row">
        <!-- Brand Filter -->
        <div class="filter-group">
          <label class="filter-label">🏷️ Brand</label>
          <select name="brand" class="filter-select" onchange="document.getElementById('filterForm').submit()">
            <option value="">All Brands</option>
            <% availableBrands.forEach(b => { %>
              <option value="<%= b %>" <%= selectedBrand === b ? 'selected' : '' %>><%= b %></option>
            <% }) %>
          </select>
        </div>

        <!-- Sort -->
        <div class="filter-group">
          <label class="filter-label">⬆️ Sort By</label>
          <select name="sort" class="filter-select" onchange="document.getElementById('filterForm').submit()">
            <option value="">Relevance</option>
            <option value="price_asc"  <%= selectedSort === 'price_asc'  ? 'selected' : '' %>>Price: Low to High</option>
            <option value="price_desc" <%= selectedSort === 'price_desc' ? 'selected' : '' %>>Price: High to Low</option>
            <option value="rating"     <%= selectedSort === 'rating'     ? 'selected' : '' %>>Top Rated</option>
            <option value="newest"     <%= selectedSort === 'newest'     ? 'selected' : '' %>>Newest First</option>
          </select>
        </div>

        <!-- Badge / Deal Filter -->
        <div class="filter-group">
          <label class="filter-label">🔥 Deals</label>
          <select name="badge" class="filter-select" onchange="document.getElementById('filterForm').submit()">
            <option value="">All</option>
            <option value="hot"      <%= selectedBadge === 'hot'      ? 'selected' : '' %>>🔥 Hot</option>
            <option value="sale"     <%= selectedBadge === 'sale'     ? 'selected' : '' %>>💰 Sale</option>
            <option value="new"      <%= selectedBadge === 'new'      ? 'selected' : '' %>>✨ New</option>
            <option value="trending" <%= selectedBadge === 'trending' ? 'selected' : '' %>>📈 Trending</option>
          </select>
        </div>

        <!-- Price Range -->
        <div class="filter-group filter-group-price">
          <label class="filter-label">💵 Price Range (₹)</label>
          <div class="price-inputs">
            <input type="number" name="minPrice" placeholder="Min" value="<%= selectedMinPrice %>" class="filter-input-price" min="0">
            <span class="price-sep">—</span>
            <input type="number" name="maxPrice" placeholder="Max" value="<%= selectedMaxPrice %>" class="filter-input-price" min="0">
            <button type="submit" class="btn-apply-filter">Apply</button>
          </div>
        </div>

        <!-- Reset -->
        <% if (selectedCategory || selectedBrand || selectedMinPrice || selectedMaxPrice || selectedSort || selectedBadge) { %>
        <div class="filter-group filter-group-reset">
          <label class="filter-label">&nbsp;</label>
          <a href="/shop<%= selectedCategory ? '?category=' + selectedCategory : '' %>" class="btn-reset-filter">✕ Reset Filters</a>
        </div>
        <% } %>
      </div>
    </form>

    <!-- Active Filter Tags -->
    <% if (selectedBrand || selectedMinPrice || selectedMaxPrice || selectedBadge) { %>
    <div class="active-filters mb-3">
      <span class="active-filters-label">Active:</span>
      <% if (selectedBrand) { %>
        <span class="active-tag">🏷️ <%= selectedBrand %></span>
      <% } %>
      <% if (selectedBadge) { %>
        <span class="active-tag">🔥 <%= selectedBadge.charAt(0).toUpperCase() + selectedBadge.slice(1) %></span>
      <% } %>
      <% if (selectedMinPrice || selectedMaxPrice) { %>
        <span class="active-tag">💵 ₹<%= selectedMinPrice || '0' %> – ₹<%= selectedMaxPrice || '∞' %></span>
      <% } %>
    </div>
    <% } %>

    <!-- Products Grid -->
    <% if (products.length === 0) { %>
    <div class="empty-state">
      <span class="empty-icon">🔍</span>
      <h3 class="empty-title">No products found</h3>
      <p style="color:var(--gray); margin-bottom:20px">Try adjusting your filters</p>
      <a href="/shop" style="background:var(--primary); color:white; padding:10px 28px; border-radius:50px; text-decoration:none; font-family:'Syne',sans-serif; font-weight:700;">View All</a>
    </div>
    <% } else { %>
    <div class="row g-4">
      <% products.forEach(product => { %>
      <div class="col-lg-3 col-md-6">
        <div class="product-card">
          <div class="product-img-wrap">
            <img src="<%= product.image %>" alt="<%= product.name %>" loading="lazy">
            <span class="product-badge <%= product.badge.toLowerCase() %>"><%= product.badge %></span>
            <a href="/product/<%= product.id %>" class="quick-view-btn">View Details</a>
          </div>
          <div class="product-info">
            <div class="product-category"><%= product.category %> • <span style="color:var(--primary);font-weight:700"><%= product.brand %></span></div>
            <a href="/product/<%= product.id %>" class="product-name"><%= product.name %></a>
            <div class="product-stars">
              ★★★★<%= product.rating >= 4.5 ? '★' : '☆' %>
              <span>(<%= product.reviews %>)</span>
            </div>
            <div class="product-price-row">
              <span class="price-current">₹<%= product.price.toLocaleString('en-IN') %></span>
              <span class="price-original">₹<%= product.originalPrice.toLocaleString('en-IN') %></span>
              <span class="price-discount">-<%= Math.round((product.originalPrice - product.price) / product.originalPrice * 100) %>%</span>
            </div>
            <button class="btn-add-cart" data-id="<%= product.id %>">Add to Cart 🛒</button>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
    <% } %>
  </div>
</section>

<%- include('partials/footer') %>
