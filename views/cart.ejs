<%- include('partials/header', { title: 'My Cart' }) %>

<section class="py-5">
  <div class="container">
    <h1 style="font-family:'Syne',sans-serif; font-weight:800; font-size:1.8rem; margin-bottom:30px;">
      🛒 My Cart <% if (cartItems.length > 0) { %><span style="font-size:1rem; font-weight:600; color:var(--gray);">(<%= cartItems.length %> item<%= cartItems.length > 1 ? 's' : '' %>)</span><% } %>
    </h1>

    <!-- Empty State -->
    <div id="empty-cart-msg" style="<%= cartItems.length === 0 ? '' : 'display:none' %>">
      <div class="empty-state">
        <span class="empty-icon">🛒</span>
        <h3 class="empty-title">Your cart is empty</h3>
        <p style="color:var(--gray); margin-bottom:24px;">Looks like you haven't added anything yet!</p>
        <a href="/shop" style="background:var(--primary); color:white; padding:12px 32px; border-radius:50px; text-decoration:none; font-family:'Syne',sans-serif; font-weight:700; font-size:0.95rem;">Start Shopping →</a>
      </div>
    </div>

    <% if (cartItems.length > 0) { %>
    <div class="row g-4">
      <!-- Cart Items -->
      <div class="col-lg-8">
        <div style="background:white; border:1px solid var(--border); border-radius:var(--radius); overflow:hidden;">
          <% cartItems.forEach((item, index) => { %>
          <div id="cart-row-<%= item.id %>" data-price="<%= item.price %>" style="padding:20px 24px; border-bottom: <%= index < cartItems.length - 1 ? '1px solid var(--border)' : 'none' %>;">
            <div class="d-flex align-items-center gap-3 flex-wrap">
              <img src="<%= item.image %>" alt="<%= item.name %>" class="cart-item-img">
              <div style="flex:1; min-width:150px;">
                <div style="font-size:0.75rem; color:var(--primary); font-weight:600; text-transform:uppercase; letter-spacing:1px; margin-bottom:3px;"><%= item.category %></div>
                <div style="font-family:'Syne',sans-serif; font-weight:700; font-size:1rem; margin-bottom:4px;">
                  <a href="/product/<%= item.id %>" style="color:var(--dark); text-decoration:none;"><%= item.name %></a>
                </div>
                <div style="font-size:0.85rem; color:var(--gray);">Unit price: ₹<%= item.price.toLocaleString('en-IN') %></div>
              </div>
              <div class="d-flex align-items-center gap-2">
                <button class="qty-btn" onclick="updateQty(<%= item.id %>, -1)">−</button>
                <span class="qty-display" id="qty-<%= item.id %>"><%= item.quantity %></span>
                <button class="qty-btn" onclick="updateQty(<%= item.id %>, 1)">+</button>
              </div>
              <div style="font-family:'Syne',sans-serif; font-weight:800; font-size:1rem; min-width:90px; text-align:right;">
                <span class="line-total">₹<%= (item.price * item.quantity).toLocaleString('en-IN') %></span>
              </div>
              <button class="btn-remove" onclick="removeItem(<%= item.id %>)" title="Remove">✕</button>
            </div>
          </div>
          <% }) %>
        </div>

        <!-- Continue Shopping -->
        <div style="margin-top:16px;">
          <a href="/shop" style="color:var(--primary); text-decoration:none; font-family:'Syne',sans-serif; font-weight:600; font-size:0.9rem;">
            ← Continue Shopping
          </a>
        </div>
      </div>

      <!-- Summary -->
      <div class="col-lg-4">
        <div class="cart-summary-box">
          <div class="cart-summary-title">Order Summary</div>
          <div class="summary-row">
            <span style="color:var(--gray);">Subtotal</span>
            <span id="summary-subtotal">₹<%= total.toLocaleString('en-IN') %></span>
          </div>
          <div class="summary-row">
            <span style="color:var(--gray);">Delivery</span>
            <span id="summary-delivery"><%= total > 0 ? '₹99' : '₹0' %></span>
          </div>
          <div class="summary-row">
            <span style="color:var(--gray);">Discount</span>
            <span style="color:var(--success);">−₹0</span>
          </div>
          <div class="summary-row summary-total">
            <span>Total</span>
            <span id="summary-total">₹<%= (total + (total > 0 ? 99 : 0)).toLocaleString('en-IN') %></span>
          </div>

          <!-- Promo hint -->
          <div style="background:var(--primary-light); border-radius:10px; padding:10px 14px; font-size:0.82rem; color:var(--primary-dark); font-family:'Syne',sans-serif; font-weight:600; margin-top:14px;">
            🎉 You're eligible for free delivery above ₹999!
          </div>

          <div id="checkout-btn">
            <% if (user) { %>
              <a href="/checkout" class="btn-checkout">Proceed to Checkout →</a>
            <% } else { %>
              <a href="/login" class="btn-checkout">Login to Checkout →</a>
            <% } %>
          </div>
        </div>
      </div>
    </div>
    <% } %>
  </div>
</section>

<%- include('partials/footer') %>
