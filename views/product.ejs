<%- include('partials/header', { title: product.name }) %>

<section class="py-5">
  <div class="container">

    <!-- Breadcrumb -->
    <nav style="margin-bottom:28px;">
      <ol class="breadcrumb" style="font-size:0.85rem;">
        <li class="breadcrumb-item"><a href="/" style="color:var(--primary); text-decoration:none;">Home</a></li>
        <li class="breadcrumb-item"><a href="/shop" style="color:var(--primary); text-decoration:none;">Shop</a></li>
        <li class="breadcrumb-item"><a href="/shop?category=<%= product.category %>" style="color:var(--primary); text-decoration:none;"><%= product.category %></a></li>
        <li class="breadcrumb-item active" style="color:var(--gray);"><%= product.name %></li>
      </ol>
    </nav>

    <div class="row g-5">
      <!-- Image -->
      <div class="col-lg-6">
        <div style="position:relative;">
          <img src="<%= product.image %>" alt="<%= product.name %>" class="product-detail-img">
          <span class="product-badge <%= product.badge.toLowerCase() %>" style="position:absolute; top:16px; left:16px; font-size:0.8rem; padding:5px 12px;">
            <%= product.badge %>
          </span>
        </div>
      </div>

      <!-- Info -->
      <div class="col-lg-6">
        <div class="product-category" style="margin-bottom:8px;"><%= product.category %></div>
        <h1 style="font-family:'Syne',sans-serif; font-weight:800; font-size:1.9rem; margin-bottom:12px; line-height:1.2;">
          <%= product.name %>
        </h1>

        <div class="product-stars" style="font-size:1rem; margin-bottom:16px;">
          ★★★★<%= product.rating >= 4.5 ? '★' : '☆' %>
          <span style="color:var(--gray); font-size:0.85rem;">(<%= product.reviews %> reviews)</span>
        </div>

        <div style="display:flex; align-items:center; gap:14px; margin-bottom:22px;">
          <span class="detail-price">₹<%= product.price.toLocaleString('en-IN') %></span>
          <span class="detail-original">₹<%= product.originalPrice.toLocaleString('en-IN') %></span>
          <span class="price-discount" style="font-size:0.85rem; padding:4px 10px;">
            Save <%= Math.round((product.originalPrice - product.price) / product.originalPrice * 100) %>%
          </span>
        </div>

        <p style="color:var(--gray); font-size:0.95rem; line-height:1.7; margin-bottom:28px; max-width:420px;">
          <%= product.description %>
        </p>

        <!-- Features -->
        <div style="background:var(--light-gray); border-radius:12px; padding:18px; margin-bottom:28px;">
          <div style="display:flex; gap:24px; flex-wrap:wrap;">
            <div style="display:flex; align-items:center; gap:8px; font-size:0.85rem;">
              <span>🚚</span> <span>Free Delivery</span>
            </div>
            <div style="display:flex; align-items:center; gap:8px; font-size:0.85rem;">
              <span>🔄</span> <span>Easy Returns</span>
            </div>
            <div style="display:flex; align-items:center; gap:8px; font-size:0.85rem;">
              <span>✅</span> <span>In Stock</span>
            </div>
          </div>
        </div>

        <!-- Add to Cart -->
        <div style="display:flex; gap:12px; align-items:center; flex-wrap:wrap;">
          <button class="btn-add-detail" data-id="<%= product.id %>">
            🛒 Add to Cart
          </button>
          <a href="/cart" style="background:transparent; color:var(--dark); border:2px solid var(--border); padding:13px 24px; border-radius:12px; font-family:'Syne',sans-serif; font-weight:700; font-size:0.95rem; text-decoration:none; transition:all 0.28s;" onmouseover="this.style.borderColor='var(--primary)'; this.style.color='var(--primary)'" onmouseout="this.style.borderColor='var(--border)'; this.style.color='var(--dark)'">View Cart</a>
        </div>
      </div>
    </div>

    <!-- Related Products -->
    <% if (related.length > 0) { %>
    <div style="margin-top:70px;">
      <div class="section-tag">You Might Also Like</div>
      <h2 class="section-title" style="margin-bottom:28px;">Related Products</h2>
      <div class="row g-4">
        <% related.forEach(p => { %>
        <div class="col-lg-4 col-md-6">
          <div class="product-card">
            <div class="product-img-wrap">
              <img src="<%= p.image %>" alt="<%= p.name %>" loading="lazy">
              <span class="product-badge <%= p.badge.toLowerCase() %>"><%= p.badge %></span>
              <a href="/product/<%= p.id %>" class="quick-view-btn">View Details</a>
            </div>
            <div class="product-info">
              <div class="product-category"><%= p.category %></div>
              <a href="/product/<%= p.id %>" class="product-name"><%= p.name %></a>
              <div class="product-price-row">
                <span class="price-current">₹<%= p.price.toLocaleString('en-IN') %></span>
                <span class="price-original">₹<%= p.originalPrice.toLocaleString('en-IN') %></span>
              </div>
              <button class="btn-add-cart" data-id="<%= p.id %>">Add to Cart 🛒</button>
            </div>
          </div>
        </div>
        <% }) %>
      </div>
    </div>
    <% } %>

  </div>
</section>

<%- include('partials/footer') %>
